{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Audiobook TTS Workbench",
  "version": "0.1.0",
  "identifier": "com.snow.meu-projeto-tts",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Audiobook TTS Workbench",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
